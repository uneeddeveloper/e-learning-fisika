# TiDB Cloud Serverless — ambil dari: https://tidbcloud.com/console/clusters
# Klik cluster → "Connect" → copy host/user/password, lalu rangkai URL berikut.
# Catatan: `?sslaccept=strict` WAJIB untuk koneksi native (prisma db push / migrate).
DATABASE_URL="mysql://USERNAME.root:PASSWORD@gateway01.region.prod.tidbcloud.com:4000/your_database?sslaccept=strict"

# Session encryption key untuk nuxt-auth-utils (min. 32 karakter, random).
# Generate: openssl rand -base64 32   atau   pwsh -c "[Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))"
NUXT_SESSION_PASSWORD="ganti-dengan-string-acak-minimal-32-karakter"
