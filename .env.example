NUXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="your-anon-public-key"

# Database (Prisma) — ambil dari: https://supabase.com/dashboard/project/_/settings/database
